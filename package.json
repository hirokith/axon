{
  "name": "axon",
  "version": "0.1.0",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "postinstall": "node scripts/patch-electron-name.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hirokith/axon.git"
  },
  "keywords": [
    "acp",
    "agent",
    "electron",
    "desktop",
    "ai"
  ],
  "author": {
    "name": "hirokith",
    "email": "hirokith@users.noreply.github.com"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/hirokith/axon/issues"
  },
  "homepage": "https://github.com/hirokith/axon#readme",
  "description": "A desktop client for ACP-powered AI Agents",
  "build": {
    "appId": "com.axon.app",
    "productName": "Axon",
    "icon": "build/icon",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "category": "Development",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^7.3.3"
  },
  "dependencies": {
    "@pierre/diffs": "^1.1.21",
    "@tailwindcss/typography": "^0.5.19",
    "@types/uuid": "^10.0.0",
    "electron-store": "^8.2.0",
    "katex": "^0.16.45",
    "lucide-react": "^1.14.0",
    "material-icon-theme": "^5.34.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^4.0.2",
    "sql.js": "^1.14.1",
    "uuid": "^14.0.0",
    "zustand": "^5.0.13"
  },
  "packageManager": "pnpm@11.1.2",
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "esbuild", "electron-winstaller"]
  }
}
